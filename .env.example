# ─────────────────────────────────────────────────────────────
# Orthogonal (required) — https://orthogonal.com/dashboard
# The pay-per-call proxy over the third-party API catalog.
# ─────────────────────────────────────────────────────────────
ORTHOGONAL_API_KEY=orth_live_xxxxxxxxxxxxxxxxxxxx
# Optional override; defaults to the production host.
ORTHOGONAL_BASE_URL=https://api.orthogonal.com

# ─────────────────────────────────────────────────────────────
# LLM provider. Default "orthogonal" runs inference through the
# Orthogonal catalog itself (Baseten chat completions, ~0.1¢/call)
# so ORTHOGONAL_API_KEY above is the only secret you need.
# Set "anthropic" or "openai" + a key for true token streaming.
# ─────────────────────────────────────────────────────────────
LLM_PROVIDER=orthogonal           # "orthogonal" | "anthropic" | "openai"
LLM_MODEL=                        # optional; defaults: zai-org/GLM-5.2 / claude-sonnet-5 / gpt-4o
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ─────────────────────────────────────────────────────────────
# Database (Postgres). Required for Meridian accounts and durable history.
# Use Neon, Vercel Postgres, or any compatible managed Postgres instance.
# ─────────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:pass@host:5432/ortho
# Single-company deployment label shown in the manager workspace.
MERIDIAN_COMPANY_NAME=Acme Corporation

# ─────────────────────────────────────────────────────────────
# Cost & safety guards (optional; sane defaults applied in code)
# ─────────────────────────────────────────────────────────────
# Hard cap on the total $ a single chat turn may spend on Orthogonal calls.
MAX_SPEND_CENTS_PER_TURN=50
# Max agent tool-calling steps per turn.
MAX_AGENT_STEPS=8

# ─────────────────────────────────────────────────────────────
# "Talk to Meridian" voice mode.
#   VOICE_PROVIDER=orthogonal (default) — single-key, push-to-talk.
#     Speech-to-text + text-to-speech run through Orthogonal (ElevenLabs),
#     chained around the existing text agent. Works with just the Orthogonal
#     key above. NOTE: speech-to-text fetches the recording by URL, so the
#     full round-trip only works when deployed at a public URL (not localhost);
#     set VOICE_PUBLIC_BASE_URL if the request host isn't publicly reachable.
#   VOICE_PROVIDER=xai — realtime Grok Voice over WebRTC (needs XAI_API_KEY).
# ─────────────────────────────────────────────────────────────
VOICE_PROVIDER=orthogonal
VOICE_ELEVEN_VOICE_ID=21m00Tcm4TlvDq8ikWAM   # ElevenLabs voice (default "Rachel")
# VOICE_PUBLIC_BASE_URL=https://your-app.vercel.app
# Hard per-voice-session caps (each turn bills STT + tools + TTS).
VOICE_MAX_SESSION_SECONDS=300
VOICE_MAX_SPEND_CENTS=50

# xAI Grok Voice (only when VOICE_PROVIDER=xai)
XAI_API_KEY=
XAI_VOICE_MODEL=grok-voice-latest
XAI_VOICE=eve
